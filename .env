# Puerto en el que correrá el servidor web local
PORT=8000

# Configuración del servidor de correo saliente (SMTP)
# Cambia estos datos por los de tu proveedor (ej. Gmail, Outlook, Zoho, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Credenciales de acceso de tu correo remitente
# Nota: Si usas Gmail o Outlook, es probable que requieras activar "Contraseñas de aplicación"
# y colocar ese token de 16 letras aquí en lugar de tu contraseña personal por seguridad.
SMTP_USER=guillermocamiloflorezerazo@gmail.com
SMTP_PASS=wzswboygvwigvaer

# Dirección de correo electrónico del destinatario (donde llegará la cotización)
DEST_EMAIL=administacion@opelcarsas.com